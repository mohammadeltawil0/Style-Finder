{
  "expo": {
    "name": "Style Finder",
    "backgroundColor": "#B08968",
    "splash": {
      "image": "./assets/images/custom-logo-2.png",
      "resizeMode": "contain",
      "backgroundColor": "#B08968"
    },
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/custom-logo-2.png",
    "scheme": "frontend",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "edgeToEdgeEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EDE0D4"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/custom-logo-2.png"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/custom-logo-2.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#B08968"
        }
      ],
      "expo-font"
    ]
  }
}
